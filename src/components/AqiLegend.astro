---
const AQI_BANDS = [
  { index: 1, label: "Good", color: "#50f0e6", description: "Minimal or no risk" },
  { index: 2, label: "Fair", color: "#50ccaa", description: "Low risk" },
  { index: 3, label: "Moderate", color: "#f0e641", description: "Possible risk for sensitive individuals" },
  { index: 4, label: "Poor", color: "#ff5050", description: "Health risk for everyone" },
  { index: 5, label: "Very Poor", color: "#960032", description: "Significant health risk" },
  { index: 6, label: "Extremely Poor", color: "#7d2181", description: "Severe health risk" },
];
---

<div class="space-y-2" role="region" aria-label="Air Quality Index legend">
  <h3 class="text-sm font-semibold text-gray-700">Air Quality Index (EEA 2024)</h3>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-1.5">
    {AQI_BANDS.map((band) => (
      <div class="flex items-center gap-1.5 px-2 py-1.5 rounded text-xs" style={`background-color: ${band.color}18; border: 1px solid ${band.color}30;`}>
        <span class="inline-block w-3 h-3 rounded flex-shrink-0" style={`background-color: ${band.color}`} aria-hidden="true"></span>
        <div class="min-w-0">
          <span class="font-medium" style={`color: ${band.color}`}>{band.index}. {band.label}</span>
        </div>
      </div>
    ))}
  </div>
</div>
