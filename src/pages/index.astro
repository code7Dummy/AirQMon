---
import DataPageLayout from "../layouts/DataPageLayout.astro";
import CurrentConditionsMap from "../components/CurrentConditionsMap.astro";
import StationCard from "../components/StationCard.astro";
import AqiLegend from "../components/AqiLegend.astro";
import ShareButtons from "../components/ShareButtons.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import type { StationCurrentData } from "../lib/types";
import { formatRelativeTime } from "../lib/format";
import { POLLUTANT_NAMES } from "../lib/labels";

let stations: StationCurrentData[] = [];
let lastUpdated = "";
let buildTimestamp = "";

try {
  const mod = await import("../data/current.json");
  const data = mod.default || mod;
  stations = data.stations || [];
  lastUpdated = data.lastUpdated || "";
  buildTimestamp = data.buildTimestamp || "";
} catch {
  // No data generated yet
}

const totalStations = stations.length;
const reportingNow = stations.filter((s) => s.measurements.length > 0).length;
const goodCount = stations.filter((s) => s.aqi === 1).length;
const fairCount = stations.filter((s) => s.aqi === 2).length;
const moderateCount = stations.filter((s) => s.aqi === 3).length;
const poorPlus = stations.filter((s) => s.aqi >= 4).length;

const nationalAvgAqi = stations.length > 0
  ? Math.round(stations.reduce((sum, s) => sum + s.aqi, 0) / stations.length)
  : 0;

const dublinStations = stations.filter(
  (s) => s.station.CITY_NAME === "Dublin" || s.station.StationName.toLowerCase().includes("dublin")
);
const dublinAvgAqi = dublinStations.length > 0
  ? Math.round(dublinStations.reduce((sum, s) => sum + s.aqi, 0) / dublinStations.length)
  : null;

function aqiBlockBg(index: number): string {
  if (index <= 1) return "#50f0e6";
  if (index === 2) return "#50ccaa";
  if (index === 3) return "#f0e641";
  if (index === 4) return "#ff5050";
  return "#960032";
}
function aqiBlockText(index: number): string {
  if (index <= 1) return "#0a6e65";
  if (index === 2) return "#1a6b52";
  if (index === 3) return "#6b5f0a";
  if (index === 4) return "#7a0a0a";
  return "#fff";
}
---

<DataPageLayout title="Current Air Quality — Ireland" description="Real-time air quality readings across Ireland. Map and list view of all active monitoring stations with European Air Quality Index." lastUpdated={lastUpdated} buildTimestamp={buildTimestamp}>
  <div class="space-y-8">
    <section aria-labelledby="intro-heading" class="text-center space-y-2">
      <h2 id="intro-heading" class="text-xl font-semibold text-gray-800">Real-time air quality in Ireland</h2>
      <p class="text-sm text-gray-600 max-w-2xl mx-auto">
        Live AQI for Dublin, Cork, Galway. PM2.5 and PM10 pollution levels updated hourly from official EEA monitoring stations across Ireland.
      </p>
    </section>

    <section aria-labelledby="today-aqi-heading">
      <h2 id="today-aqi-heading" class="text-lg font-bold mb-3">Today's Air Quality Summary</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-lg p-4 text-center border" style={`background-color: ${aqiBlockBg(nationalAvgAqi)}20; border-color: ${aqiBlockBg(nationalAvgAqi)}40;`}>
          <div class="text-3xl font-bold" style={`color: ${aqiBlockText(nationalAvgAqi)}`}>{nationalAvgAqi}</div>
          <div class="text-sm font-medium mt-1" style={`color: ${aqiBlockText(nationalAvgAqi)}`}>
            National Average AQI
          </div>
          <div class="text-xs mt-1" style={`color: ${aqiBlockText(nationalAvgAqi)}80`}>
            {stations.length} station{stations.length !== 1 ? "s" : ""} across Ireland
          </div>
        </div>
        {dublinAvgAqi !== null && (
          <div class="rounded-lg p-4 text-center border" style={`background-color: ${aqiBlockBg(dublinAvgAqi)}20; border-color: ${aqiBlockBg(dublinAvgAqi)}40;`}>
            <div class="text-3xl font-bold" style={`color: ${aqiBlockText(dublinAvgAqi)}`}>{dublinAvgAqi}</div>
            <div class="text-sm font-medium mt-1" style={`color: ${aqiBlockText(dublinAvgAqi)}`}>
              Dublin Average AQI
            </div>
            <div class="text-xs mt-1" style={`color: ${aqiBlockText(dublinAvgAqi)}80`}>
              {dublinStations.length} station{dublinStations.length !== 1 ? "s" : ""} in Dublin area
            </div>
          </div>
        )}
      </div>
    </section>

    <section aria-labelledby="map-heading">
      <h2 id="map-heading" class="sr-only">Air quality map of Ireland</h2>
      <CurrentConditionsMap stations={stations} />
    </section>

    <ShareButtons />

    <section aria-labelledby="summary-heading" class="grid grid-cols-2 sm:grid-cols-5 gap-3">
      <h2 id="summary-heading" class="sr-only">Summary statistics</h2>
      <div class="rounded-lg p-3 text-center bg-blue-50">
        <div class="text-2xl font-bold text-blue-700">{totalStations}</div>
        <div class="text-xs text-blue-600">Active Stations</div>
      </div>
      <div class="rounded-lg p-3 text-center bg-green-50">
        <div class="text-2xl font-bold text-green-700">{reportingNow}</div>
        <div class="text-xs text-green-600">Reporting Now</div>
      </div>
      <div class="rounded-lg p-3 text-center" style="background-color: #50f0e620">
        <div class="text-2xl font-bold" style="color: #0a6e65">{goodCount}</div>
        <div class="text-xs" style="color: #0a6e65">Good AQI</div>
      </div>
      <div class="rounded-lg p-3 text-center" style="background-color: #50ccaa20">
        <div class="text-2xl font-bold" style="color: #1a6b52">{fairCount}</div>
        <div class="text-xs" style="color: #1a6b52">Fair AQI</div>
      </div>
      <div class="rounded-lg p-3 text-center" style="background-color: #ff505020">
        <div class="text-2xl font-bold" style="color: #7a0a0a">{poorPlus}</div>
        <div class="text-xs" style="color: #7a0a0a">Poor+ AQI</div>
      </div>
    </section>

    <AqiLegend />

    <section aria-labelledby="stations-heading">
      <div class="flex items-center justify-between mb-4">
        <h2 id="stations-heading" class="text-xl font-bold">Monitoring Stations</h2>
        <span class="text-sm text-gray-500">{totalStations} stations</span>
      </div>
      {stations.length > 0 ? (
        <div id="station-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" role="list">
          {stations.map((s) => (
            <div role="listitem" key={s.station.AirQualityStationEoICode}>
              <StationCard data={s} />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 text-gray-500 border border-dashed border-gray-300 rounded-lg">
          <p class="text-lg font-medium">No station data available</p>
          <p class="text-sm mt-1">Data will appear once the data pipeline runs. See <a href="/methodology/" class="text-blue-600 underline">Methodology</a> for details.</p>
        </div>
      )}
    </section>

    <NewsletterSignup />
  </div>
</DataPageLayout>
